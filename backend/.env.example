# JobLyne Backend Environment Config
# Copy this to .env and fill in the values

# Django Settings
# Generate a secure key for production: python -c 'import secrets; print(secrets.token_urlsafe(50))'
SECRET_KEY=your-django-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.localhost

# Database (Neon PostgreSQL or local Postgres)
# Format: postgresql://[user]:[password]@[endpoint]/[dbname]?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/joblyne

# Social Auth (Optional but recommended for full testing)
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
LINKEDIN_OAUTH_CLIENT_ID=your-linkedin-client-id
LINKEDIN_OAUTH_CLIENT_SECRET=your-linkedin-client-secret
